{
  "name": "weave-lang-syntax",
  "displayName": "Weave",
  "description": "Syntax highlighting for the Weave language (.weave files).",
  "version": "0.0.1",
  "publisher": "pythonluvr",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      { "id": "weave", "aliases": ["Weave", "weave"], "extensions": [".weave"], "configuration": "./language-configuration.json" }
    ],
    "grammars": [
      { "language": "weave", "scopeName": "source.weave", "path": "./weave.tmLanguage.json" }
    ]
  },
  "license": "MIT"
}
